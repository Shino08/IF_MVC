# ── IF_MVC/public/.htaccess ───────────────────────────────────────────────────
# Front Controller: redirige todas las peticiones hacia index.php
# ──────────────────────────────────────────────────────────────────────────────

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Establece la base de reescritura al directorio public/ dentro del proyecto
    RewriteBase /IF_MVC/public/

    # 1. Si el archivo o directorio existe físicamente → sirve directamente
    #    (css, img, js, favicon.ico, etc.)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # 2. Todo lo demás → Front Controller
    RewriteRule ^ index.php [L]
</IfModule>

# Seguridad: bloquear acceso a archivos sensibles
<FilesMatch "\.(env|git|log|sh|bak|sql)$">
    Require all denied
</FilesMatch>
