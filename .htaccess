# ── IF_MVC/.htaccess ──────────────────────────────────────────────────────────
# Archivo de configuración único para Apache.
# Enruta todo el tráfico hacia public/ y actúa como Front Controller.
# ──────────────────────────────────────────────────────────────────────────────

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Si la petición apunta a un archivo/directorio real, lo sirve
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Si no es un archivo real, redirige al front controller de public/
    RewriteRule ^(.*)$ public/index.php [QSA,L]
</IfModule>

# Seguridad: bloquear acceso a archivos sensibles y de configuración
<FilesMatch "(^#.*#|\.(bak|env|config|sql|sh|log|json|lock|gitid|git))$">
    Require all denied
</FilesMatch>
